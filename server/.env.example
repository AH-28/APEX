# Copy to .env (or export in your shell) — the server reads process.env directly.
PORT=3000
DB_PATH=apex.db
JWT_SECRET=replace-with-a-long-random-string

# Optional: enables AI quest personalisation. Without it the server runs in
# deterministic fallback mode (quests still generate from template examples).
ANTHROPIC_API_KEY=
# Model used for variable filling (see docs/ARCHITECTURE.md for cost notes).
QUEST_MODEL=claude-opus-4-8
